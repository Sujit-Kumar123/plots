# Auth Service — copy to .env and fill in your values.
# Never commit .env — it is git-ignored.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Internal service authentication ──────────────────────────────────────────
# Verified by InternalAuthMiddleware on /internal/* endpoints.
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mvp_user:mvp_pass@postgres:5432/mvp_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis (sessions + rate limiting) ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ── Auth method toggles ───────────────────────────────────────────────────────
AUTH_EMAIL_ENABLED=true
AUTH_GOOGLE_ENABLED=false
AUTH_AZURE_ENABLED=false

# ── CORS & URLs ───────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost","http://localhost:3000"]
FRONTEND_URL=http://localhost:3000
EMAIL_SERVICE_URL=http://email-service:8013

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Azure OAuth ───────────────────────────────────────────────────────────────
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common
AZURE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/azure/callback

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_PASSWORD_RESET=3/minute
