# Plot Service — copy to .env and fill in your values.
# Never commit .env — it is git-ignored.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Internal service authentication ──────────────────────────────────────────
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string

# ── Database (plot_unified schema) ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mvp_user:mvp_pass@postgres:5432/mvp_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Kafka producer (command side) ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PRODUCER_ACKS=all
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RETRY_BACKOFF_MS=500
KAFKA_PUBLISH_RETRIES=3

# ── Kafka consumer (projection side) ─────────────────────────────────────────
KAFKA_CONSUMER_GROUP=plot-query-projector
KAFKA_CONSUMER_MAX_RETRIES=3
KAFKA_CONSUMER_RETRY_BACKOFF=0.5

# ── Topics ─────────────────────────────────────────────────────────────────────
TOPIC_PLOT_EVENTS=plot.events
TOPIC_PLOT_BULK=plot.bulk.commands

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Domain limits ─────────────────────────────────────────────────────────────
MAX_PLOT_ELEMENTS=10000
