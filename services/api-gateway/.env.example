# API Gateway — copy to .env and fill in your values.
# Never commit .env — it is git-ignored.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# JWT signing secret — must match auth-service SECRET_KEY
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Internal service authentication ──────────────────────────────────────────
# Shared secret sent as x-internal-secret header on every proxied request.
# Must match INTERNAL_SERVICE_SECRET on all downstream services.
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string

# ── Downstream service URLs ───────────────────────────────────────────────────
# In Docker use container names; for local dev use localhost + the service port.
CHAT_COMMAND_URL=http://chat-command:8001
CHAT_QUERY_URL=http://chat-query:8002
PLOT_COMMAND_URL=http://plot-command:8003
PLOT_QUERY_URL=http://plot-query:8004
AUTH_SERVICE_URL=http://auth-service:8010
PAYMENT_SERVICE_URL=http://payment-service:8011
NOTIFICATION_SERVICE_URL=http://notification-service:8012
EMAIL_SERVICE_URL=http://email-service:8013

# ── Redis (rate limiting + session cache) ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# ── Proxy settings ────────────────────────────────────────────────────────────
PROXY_CONNECT_TIMEOUT=5.0
PROXY_READ_TIMEOUT=60.0
PROXY_MAX_RETRIES=3

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_API=300/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_PASSWORD_RESET=3/minute
