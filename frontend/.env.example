# Frontend (Next.js) — copy to .env.local and fill in your values.
# Never commit .env.local — it is git-ignored.

# ── Auth provider toggles (shown/hidden in the login UI) ─────────────────────
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_AZURE_ENABLED=false

# ── API Gateway URL (server-side rewrites only) ───────────────────────────────
# In Docker Compose the gateway is at http://api-gateway:8000.
# For local dev (no Docker) set to http://localhost:8000.
# Leave unset to use the default in next.config.ts (localhost:8000).
# BACKEND_INTERNAL_URL=http://api-gateway:8000
