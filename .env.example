# Copy this file to .env and fill in your values.
# Never commit .env — it is git-ignored.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=mvp-backend
APP_ENV=development          # development | production | testing
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mvp_user:mvp_pass@localhost:5432/mvp_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_USER=mvp_user
POSTGRES_PASSWORD=mvp_pass
POSTGRES_DB=mvp_db
POSTGRES_PORT=5432

# ── pgAdmin (Docker) ──────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@mvp.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# ── Redis Commander (Docker) ──────────────────────────────────────────────────
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin
REDIS_COMMANDER_PORT=8081

# ── Docker ports ──────────────────────────────────────────────────────────────
APP_PORT=80
NGINX_PORT=80

# ── Auth method toggles ───────────────────────────────────────────────────────
# Backend: enable/disable each provider
AUTH_EMAIL_ENABLED=true
AUTH_GOOGLE_ENABLED=false
AUTH_AZURE_ENABLED=false

# Frontend: show/hide SSO buttons (must match the backend flags above)
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_AZURE_ENABLED=false

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# ── CORS & URLs ───────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
FRONTEND_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Azure OAuth ───────────────────────────────────────────────────────────────
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common
AZURE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/azure/callback

# ── Frontend / Next.js ────────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix exposes vars to the browser at build time.
# Leave unset → relative /api is used (works in Docker via Nginx AND local dev
# via the Next.js rewrites proxy that forwards /api/* → localhost:8000).
# Override only if you need an explicit absolute URL (e.g. staging/prod).
# NEXT_PUBLIC_API_URL=http://localhost/api

# Internal URL Next.js uses (server-side rewrite) to reach the FastAPI backend.
# In Docker, point this to the container name: http://backend:8000
# In local dev (no Docker), leave as the default localhost:8000.
# BACKEND_INTERNAL_URL=http://localhost:8000
